            background: #e2e8f0 !important;
            color: #64748b !important;
        }

        .typing-dots {
            display: flex;
            gap: 6px;
        }

        .typing-dots span {
            width: 8px;
            height: 8px;
            background: #64748b;
            border-radius: 50%;
            animation: bounce 1.4s infinite;
        }

        @keyframes bounce {
            0%, 60%, 100% { transform: translateY(0); }
            30% { transform: translateY(-8px); }
        }

        .input-zone {
            display: flex;
            padding: 25px;
            background: white;
            border-top: 1px solid #edf2f7;
        }

        .input-zone input {
            flex: 1;
            padding: 18px 25px;
            border: 1px solid #e2e8f0;
            border-radius: 40px;
            margin-left: 15px;
            outline: none;
            font-size: 15px;
            transition: all 0.2s;
        }

        .input-zone input:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

