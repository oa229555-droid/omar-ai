            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 35px;
        }

        .stat-card {
            background: white;
            padding: 20px;
            border-radius: 30px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.02);
            display: flex;
            align-items: center;
            gap: 15px;
            border: 1px solid rgba(0, 0, 0, 0.02);
        }

        .stat-icon {
            width: 55px;
            height: 55px;
            background: #f8fafc;
            border-radius: 18px;
