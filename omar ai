        // ===== عناصر DOM =====
        const elements = {
            grid: document.getElementById('consultantsGrid'),
            chatArena: document.getElementById('chatArena'),
            messagesArea: document.getElementById('messagesArea'),
            messageInput: document.getElementById('messageInput'),
            sendButton: document.getElementById('sendButton'),
            backButton: document.getElementById('backButton'),
            chatConsultantInfo: document.getElementById('chatConsultantInfo'),
            filtersSection: document.getElementById('filtersSection'),
            consultantsCount: document.getElementById('consultantsCount')
        };

        // ===== حالة التطبيق =====
        const state = {
            currentConsultant: null,
            isWaiting: false,
            messageHistory: {},
            currentFilter: 'الكل'
        };

        // ===== إنشاء الفلاتر =====
        const fields = ['الكل', ...new Set(consultants.map(c => c.field))];
        
        const filterHtml = fields.map(field => 
            `<span class="filter-tag ${field === 'الكل' ? 'active' : ''}" onclick="filterConsultants('${field}')">${field}</span>`
        ).join('');
        
        elements.filtersSection.innerHTML = `
            <div class="filters-header">
                <i class="fas fa-filter"></i>
                <h3>تصفح حسب التخصص</h3>
            </div>
            <div class="filters-tags">
                ${filterHtml}
            </div>
        `;

        // ===== دالة الفلترة =====
        window.filterConsultants = (field) => {
            state.currentFilter = field;
            
            document.querySelectorAll('.filter-tag').forEach(tag => {
                tag.classList.remove('active');
                if (tag.textContent === field) tag.classList.add('active');
            });
            
            renderConsultants(field);
        };

        // ===== عرض المستشارين =====
        function renderConsultants(filter = 'الكل') {
            elements.grid.innerHTML = '';
            
            const filtered = filter === 'الكل' 
                ? consultants 
                : consultants.filter(c => c.field === filter);
            
            elements.consultantsCount.textContent = filtered.length;
            
            filtered.forEach(c => {
                const card = document.createElement('div');
                card.className = 'consultant-card';
                card.innerHTML = `
                    <div class="card-header">
                        <div class="consultant-avatar" style="background: ${c.color};">${c.avatar}</div>
                        <div class="consultant-info">
                            <div class="consultant-name">${c.name}</div>
                            <div class="consultant-title">${c.role}</div>
                            <span class="field-badge">${c.field}</span>
                        </div>
                    </div>
                    <div class="personality-badge">
                        <i class="fas fa-comment-dots" style="margin-left: 5px;"></i>
                        ${c.personality}
                    </div>
                    <div class="consultant-stats">
                        <div class="stat-cell">
                            <div class="stat-cell-value">${c.exp}</div>
                            <div class="stat-cell-label">سنوات</div>
                        </div>
                        <div class="stat-cell">
                            <div class="stat-cell-value">⭐ ${c.rating}</div>
                            <div class="stat-cell-label">تقييم</div>
                        </div>
                        <div class="stat-cell">
                            <div class="stat-cell-value">${Math.floor(Math.random() * 200) + 100}</div>
                            <div class="stat-cell-label">استشارة</div>
                        </div>
                    </div>
                    <button class="chat-button" onclick="selectConsultant(${c.id})">
                        <i class="fas fa-comment"></i>
                        تحدث مع ${c.name}
                    </button>
                `;
                elements.grid.appendChild(card);
            });
        }

        // ===== اختيار مستشار =====
        window.selectConsultant = (id) => {
            const c = consultants.find(c => c.id === id);
            if (!c) return;
            
            state.currentConsultant = c;
            
            elements.chatConsultantInfo.innerHTML = `
                <div class="chat-avatar" style="background: ${c.color};">${c.avatar}</div>
                <div>
                    <div style="font-weight: 600; font-size: 18px;">${c.name}</div>
                    <div style="font-size: 13px; opacity: 0.9;">${c.role} • ${c.field}</div>
                </div>
            `;
            
            elements.chatArena.style.display = 'block';
            
            // إنشاء شخصية فريدة لكل مستشار
            if (!state.messageHistory[id]) {
                state.messageHistory[id] = [
                    { 
                        role: 'system', 
                        content: `أنت ${c.name}، ${c.role} متخصص في ${c.field}. شخصيتك: ${c.personality}. 
                        ردودك تعكس شخصيتك الفريدة. تحدث كخبير حقيقي في مجالك. استخدم أسلوبك الخاص.` 
                    },
                    { 
                        role: 'assistant', 
                        content: `مرحباً! أنا ${c.name}، ${c.role}. ${c.personality}. كيف أقدر أساعدك في مجال ${c.field} اليوم؟` 
                    }
                ];
            }
            
            displayMessages();
        };

        // ===== عرض الرسائل =====
        function displayMessages() {
            if (!state.currentConsultant) return;
            
            elements.messagesArea.innerHTML = '';
            const history = state.messageHistory[state.currentConsultant.id];
            
            history.forEach(msg => {
                if (msg.role === 'system') return;
                
                const row = document.createElement('div');
                row.className = `message-row ${msg.role === 'user' ? 'message-user' : 'message-bot'}`;
                row.innerHTML = `<div class="message-content">${msg.content}</div>`;
                elements.messagesArea.appendChild(row);
            });
            
            elements.messagesArea.scrollTop = elements.messagesArea.scrollHeight;
        }

        // ===== إضافة رسالة =====
        function addMessage(text, role) {
            if (!state.currentConsultant) return;
            
            const row = document.createElement('div');
            row.className = `message-row ${role}`;
            row.innerHTML = `<div class="message-content">${text}</div>`;
            elements.messagesArea.appendChild(row);
            
            state.messageHistory[state.currentConsultant.id].push({ role: role === 'user' ? 'user' : 'assistant', content: text });
            elements.messagesArea.scrollTop = elements.messagesArea.scrollHeight;
        }

        // ===== مؤشر الكتابة =====
        function showTyping() {
            const typingRow = document.createElement('div');
            typingRow.className = 'message-row message-bot typing';
            typingRow.id = 'typingIndicator';
            typingRow.innerHTML = '<div class="message-content"><div class="typing-dots"><span></span><span></span><span></span></div></div>';
            elements.messagesArea.appendChild(typingRow);
            elements.messagesArea.scrollTop = elements.messagesArea.scrollHeight;
        }

        function hideTyping() {
            document.getElementById('typingIndicator')?.remove();
        }

        // ===== الاتصال بالذكاء الاصطناعي بمفتاح واحد =====
        async function getAIResponse() {
            const messages = state.messageHistory[state.currentConsultant.id];
            
            try {
                const response = await fetch('https://openrouter.ai/api/v1/chat/completions', {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${AI_KEY}`,
                        'Content-Type': 'application/json',
                        'HTTP-Referer': window.location.origin,
                    },
                    body: JSON.stringify({
                        model: 'openai/gpt-3.5-turbo',
                        messages: messages,
                        max_tokens: 250,
                        temperature: 0.8
                    })
                });

                if (response.ok) {
                    const data = await response.json();
                    return data.choices[0].message.content;
                }
            } catch (e) {
                console.log('خطأ في الاتصال:', e);
            }
            
            return null;
        }

        // ===== رد احتياطي =====
        function getFallbackResponse() {
            const c = state.currentConsultant;
            const fallbacks = [
                `أهلاً، أنا ${c.name}. شكراً لسؤالك. دقيقة للتفكير...`,
                `بصفتي ${c.role}، أرى أن سؤالك مهم. دعني أجبك بدقة.`,
                `هذا سؤال رائع في مجال ${c.field}. حسب خبرتي...`,
                `سأجيبك حالاً بعد تحليل دقيق لسؤالك.`
            ];
            return fallbacks[Math.floor(Math.random() * fallbacks.length)];
        }

        // ===== إرسال رسالة =====
        async function handleSend() {
            const text = elements.messageInput.value.trim();
            if (!text || !state.currentConsultant || state.isWaiting) return;
            
            elements.messageInput.value = '';
            state.isWaiting = true;
            elements.sendButton.disabled = true;
            
            addMessage(text, 'user');
            showTyping();
            
            const aiResponse = await getAIResponse();
            
            hideTyping();
            
            if (aiResponse) {
                addMessage(aiResponse, 'bot');
            } else {
                addMessage(getFallbackResponse(), 'bot');
            }
            
            state.isWaiting = false;
            elements.sendButton.disabled = false;
        }

        // ===== رجوع =====
        elements.backButton.addEventListener('click', () => {
            elements.chatArena.style.display = 'none';
            state.currentConsultant = null;
        });

        // ===== أحداث الإرسال =====
        elements.sendButton.addEventListener('click', handleSend);
        
        elements.messageInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                handleSend();
            }
        });

        // ===== بدء التطبيق =====
        renderConsultants();
        
        console.log('✅ منصة 80 مستشار شغالة بمفتاح واحد');
    </script>
