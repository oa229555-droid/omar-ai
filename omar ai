            width: 65px;
            height: 65px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            border: none;
            font-size: 20px;
            cursor: pointer;
            transition: 0.2s;
        }

        .input-zone button:hover:not(:disabled) {
            transform: scale(1.05);
        }

        .input-zone button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

