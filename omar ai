            gap: 20px;
            color: #64748b;
        }

        .dev-contact i {
            color: #667eea;
            margin-left: 5px;
        }

        .dev-badge {
            background: #f1f5f9;
            padding: 10px 25px;
            border-radius: 40px;
            color: #334155;
            font-weight: 500;
        }

        /* ===== إحصائيات هادئة ===== */
