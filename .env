# .env
# TITAN-OMEGA Environment Configuration

# Security Keys
TITAN_MASTER_KEY=your-256-bit-master-key-here-change-in-production
TITAN_SIGNING_KEY=your-512-bit-signing-key-here-change-in-production

# Database
REDIS_PASSWORD=titan_redis_secure_password_2026
POSTGRES_PASSWORD=titan_postgres_secure_password_2026

# API Keys (اختياري - للخدمات الخارجية)
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...

# Deployment
DEPLOYMENT_TIER=SOVEREIGN
SECURITY_CLEARANCE=TOP_SECRET
INSTANCE_ID=titan-omega-001

# Model Configuration
MODEL_DIMENSION=2048
MODEL_DEPTH=24
MODEL_HEADS=16
MAX_SEQUENCE_LENGTH=32768
VOCABULARY_SIZE=128000

# Training
TRAINING_BATCH_SIZE=32
TRAINING_LEARNING_RATE=0.0001
TRAINING_EPOCHS=10
AUTO_TRAIN_INTERVAL_HOURS=24

# Performance
USE_GPU=true
MIXED_PRECISION=true
NUM_WORKERS=4
MAX_CONCURRENT_REQUESTS=10000

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
LOG_LEVEL=INFO
LOG_FORMAT=json
