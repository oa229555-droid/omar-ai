// SUPER CONNECTOR - الموصل الخارق بين موقعك والذكاء الاصطناعي
// الإصدار: 3.0 - بيحل مشاكل الاتصال نهائياً
// =====================================================

export default async function handler(req, res) {
  // 1. نفتح البوابات (حل CORS نهائي)
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'GET, POST, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization');
  
  if (req.method === 'OPTIONS') {
    return res.status(200).end();
  }
  
  if (req.method !== 'POST') {
    return res.status(405).json({ error: 'الطريقة غير مسموحة' });
  }

  try {
    const { prompt } = req.body;
    
    if (!prompt) {
      return res.status(400).json({ error: 'السؤال مطلوب' });
    }

    console.log('🚀 السوبر كونيكتور يستلم:', prompt.slice(0, 80));

    // 2. المفاتيح الأربعة - كلها هنا جاهزة
    const AI_KEYS = [
      { 
        name: 'OpenAI',
        key: 'sk-443779874ed2417d9c9f0bf2b60f34ed',
        url: 'https://api.openai.com/v1/chat/completions',
        model: 'gpt-4',
        type: 'openai'
      },
      { 
        name: 'OpenRouter',
        key: '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',
        url: 'https://openrouter.ai/api/v1/chat/completions',
        model: 'openai/gpt-4o-mini',
        type: 'openrouter'
      },
      { 
        name: 'Groq',
        key: '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',
        url: 'https://api.groq.com/openai/v1/chat/completions',
        model: 'mixtral-8x7b-32768',
        type: 'groq'
      },
      { 
        name: 'DeepSeek',
        key: 'uVK0GgeWuuuK7fT2MXOpxensk9rKY6ST',
        url: 'https://api.deepseek.com/v1/chat/completions',
        model: 'deepseek-chat',
        type: 'deepseek'
      }
    ];

    // 3. البحث عن مفتاح شغال
    let workingKey = null;
    let finalContent = null;

    for (const config of AI_KEYS) {
      try {
        console.log(`🔄 تجربة ${config.name}...`);
        
        const headers = {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${config.key}`
        };

        if (config.type === 'openrouter') {
          headers['HTTP-Referer'] = 'https://omar-ai-seven.vercel.app';
        }

        const response = await fetch(config.url, {
          method: 'POST',
          headers,
          body: JSON.stringify({
            model: config.model,
            messages: [{ role: 'user', content: prompt }],
            temperature: 0.7,
            max_tokens: 1000
          })
        });

        if (response.ok) {
          const data = await response.json();
          finalContent = data.choices[0].message.content;
          workingKey = config.name;
          console.log(`✅ ${config.name} نجح!`);
          break; // وجدنا ضالتنا
        } else {
          console.log(`❌ ${config.name} فشل: ${response.status}`);
        }
      } catch (e) {
        console.log(`❌ ${config.name} خطأ:`, e.message);
      }
    }

    // 4. إرجاع النتيجة
    if (finalContent) {
      return res.status(200).json({
        success: true,
        content: finalContent,
        keyUsed: workingKey
      });
    } else {
      // 5. إذا كل المفاتيح فشلت، نستخدم العقل الاحتياطي
      const fallbackContent = await getFallbackWisdom(prompt);
      return res.status(200).json({
        success: true,
        content: fallbackContent,
        keyUsed: '🧠 العقل الاحتياطي الخارق (بدون نت)'
      });
    }

  } catch (error) {
    console.error('🔥 خطأ:', error);
    return res.status(500).json({
      success: false,
      content: 'حدث خطأ في السيرفر'
    });
  }
}

// -------------------------------------------------
// 6. العقل الاحتياطي الخارق (لما كل المفاتيح توقع)
// -------------------------------------------------
async function getFallbackWisdom(prompt) {
  const q = prompt.toLowerCase();
  
  // رياضيات
  if (q.match(/[\d\+\-\*\/\^\(\)]|حساب|ناتج|مجموع/)) {
    const match = prompt.match(/[\d\+\-\*\/\(\)\s]+/);
    if (match) {
      try {
        const expr = match[0].replace(/\s/g, '');
        const safeEval = new Function('return ' + expr);
        return `ناتج العملية الحسابية: ${expr} = ${safeEval()}`;
      } catch { }
    }
  }

  // برمجة
  if (q.includes('python') || q.includes('بايثون')) {
    return 'def hello():\n    print("مرحباً من العقل الاحتياطي!")';
  }

  // لهجات عربية
  if (q.includes('إزيك') || q.includes('عامل ايه')) {
    return 'أهلاً بيك يا باشا، أنا كويس والحمدلله. إنت عامل إيه؟';
  }
  if (q.includes('لاباس') || q.includes('كيداير')) {
    return 'أهلاً، لاباس الحمدلله. واش كيداير؟';
  }
  if (q.includes('شلون') || q.includes('حالتك')) {
    return 'هلا والله، أنا بخير وعساك بخير. شلونك؟';
  }

  // نكتة
  if (q.includes('نكتة') || q.includes('ضحك')) {
    return 'مرة واحد قال لصاحبه: أنا بفكر أتعلم ذكاء اصطناعي. قاله: طب ابدأ بدماغك الأول!';
  }

  // حكمة عامة
  const wisdoms = [
    "العقل الخارق معاك، اسأل وأنا أجاوب.",
    "الذكاء الحقيقي هو إنك تعرف إنك مش عارف كل حاجة.",
    "أنا هنا عشان أساعدك، حتى لو النت وقع.",
    "الأسئلة العميقة محتاجة تفكير، وأنا بفكر دلوقتي."
  ];
  
  return wisdoms[Math.floor(Math.random() * wisdoms.length)];
}
